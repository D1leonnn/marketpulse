    {
      "parameters": {
        "jsCode": "const cutoff = new Date(Date.now() - 24 * 60 * 60 * 1000);\nconst seen = new Set();\nconst results = [];\nfor (const item of $input.all()) {\n  const pub = new Date(item.json.isoDate || item.json.pubDate || 0);\n  if (pub < cutoff) continue;\n  const key = (item.json.title || '').toLowerCase().trim().substring(0, 60);\n  if (seen.has(key)) continue;\n  seen.add(key);\n  results.push(item);\n}\nreturn results.length > 0 ? results : $input.all();"
      },
      "id": "node-16",
      "name": "Filter & Deduplicate",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1900, 815]
    },
